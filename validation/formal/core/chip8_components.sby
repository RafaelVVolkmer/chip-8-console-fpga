[options]
mode bmc
depth 2

[engines]
smtbmc

[script]
read -formal -sv \
  chip8_pkg.sv \
  chip8_alu_pkg.sv \
  chip8_isa_pkg.sv \
  chip8_display_pkg.sv \
  chip8_periph_pkg.sv \
  chip8_core_pkg.sv \
  chip8_alu.sv \
  chip8_bcd.sv \
  chip8_bcd_writer.sv \
  chip8_draw_sequencer.sv \
  chip8_mem_burst.sv \
  chip8_decode.sv \
  chip8_skip_unit.sv \
  chip8_fetch.sv \
  chip8_wait_key_unit.sv \
  chip8_keypad.sv \
  chip8_io_mux.sv \
  chip8_delay_timer.sv \
  chip8_sound_timer.sv \
  chip8_framebuffer.sv \
  chip8_sprite_blitter.sv \
  chip8_components_formal.sv
prep -top chip8_components_formal

